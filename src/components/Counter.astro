---
// Counter.astro
// Calcula los días desde la última cerveza — lee fecha de localStorage (client-side)
---

<div class="text-center">
  <!-- Etiqueta superior estilo vintage -->
  <p
    id="counter-date-label"
    class="animate-fade delay-100 font-display uppercase tracking-[0.35em] mb-6"
    style="font-size: 0.9rem; color: var(--color-amber); opacity: 0;"
  >
    &nbsp;
  </p>

  <!-- Número principal animado -->
  <div class="relative inline-block animate-count delay-200" style="opacity: 0;">
    <span
      id="days-counter"
      class="font-display font-black leading-none select-none"
      style="
        font-size: clamp(9rem, 28vw, 22rem);
        color: var(--color-amber);
        line-height: 0.85;
        letter-spacing: -0.02em;
      "
    >0</span>
  </div>

  <!-- Etiqueta "días" -->
  <div class="animate-fade-up delay-400 mt-2" style="opacity: 0;">
    <span
      class="font-display font-bold uppercase tracking-[0.5em] text-2xl md:text-4xl"
      style="color: var(--color-cream-dim);"
    >
      días sin chela
    </span>
  </div>

  <!-- Separador ornamental -->
  <div class="flex items-center justify-center gap-4 mt-10 mb-8 animate-fade delay-500" style="opacity: 0;">
    <div class="h-px flex-1 max-w-24 animate-line" style="background: var(--color-amber-dim);"></div>
    <span class="font-serif italic text-lg" style="color: var(--color-amber);">✦</span>
    <div class="h-px flex-1 max-w-24 animate-line delay-100" style="background: var(--color-amber-dim);"></div>
  </div>

  <!-- Desglose semanas / meses -->
  <div class="flex justify-center gap-12 animate-fade-up delay-600" style="opacity: 0;">
    <div class="text-center">
      <div
        id="counter-weeks"
        class="font-display font-bold"
        style="font-size: clamp(2rem, 6vw, 3.5rem); color: var(--color-gold); line-height: 1;"
      >0</div>
      <div
        id="counter-weeks-label"
        class="font-display uppercase tracking-widest mt-1"
        style="font-size: 0.8rem; color: var(--color-cream-dim); letter-spacing: 0.12em;"
      >semanas</div>
    </div>

    <div style="width: 1px; background: oklch(72% 0.18 72 / 0.25);"></div>

    <div class="text-center">
      <div
        id="counter-months"
        class="font-display font-bold"
        style="font-size: clamp(2rem, 6vw, 3.5rem); color: var(--color-gold); line-height: 1;"
      >0</div>
      <div
        id="counter-months-label"
        class="font-display uppercase tracking-widest mt-1"
        style="font-size: 0.8rem; color: var(--color-cream-dim); letter-spacing: 0.12em;"
      >meses</div>
    </div>
  </div>
</div>

<script>
  import { getStartDate, calcDays, formatDate } from '../scripts/dateStore.js';

  function easeOutExpo(t: number): number {
    return t === 1 ? 1 : 1 - Math.pow(2, -10 * t);
  }

  function animateCount(el: HTMLElement, target: number, duration = 1400) {
    const startTime = performance.now();
    function update(now: number) {
      const elapsed = now - startTime;
      const progress = Math.min(elapsed / duration, 1);
      el.textContent = Math.round(easeOutExpo(progress) * target).toString();
      if (progress < 1) requestAnimationFrame(update);
    }
    setTimeout(() => requestAnimationFrame(update), 300);
  }

  function render() {
    const startDate = getStartDate();
    const totalDays = calcDays(startDate);
    const weeks = Math.floor(totalDays / 7);
    const months = (totalDays / 30.44).toFixed(1);

    // Etiqueta de fecha
    const dateLabel = document.getElementById('counter-date-label');
    if (dateLabel) {
      dateLabel.textContent = `Última chela — ${formatDate(startDate)}`;
    }

    // Número principal
    const counterEl = document.getElementById('days-counter');
    if (counterEl) {
      counterEl.setAttribute('data-target', totalDays.toString());
      animateCount(counterEl, totalDays);
    }

    // Semanas
    const weeksEl = document.getElementById('counter-weeks');
    const weeksLabel = document.getElementById('counter-weeks-label');
    if (weeksEl) weeksEl.textContent = weeks.toString();
    if (weeksLabel) weeksLabel.textContent = weeks === 1 ? 'semana' : 'semanas';

    // Meses
    const monthsEl = document.getElementById('counter-months');
    const monthsLabel = document.getElementById('counter-months-label');
    if (monthsEl) monthsEl.textContent = months;
    if (monthsLabel) monthsLabel.textContent = parseFloat(months) === 1 ? 'mes' : 'meses';
  }

  render();

  // Re-renderizar cuando el usuario configura su fecha
  window.addEventListener('date-updated', render);
</script>
